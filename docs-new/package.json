{
  "name": "docs-new",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "node scripts/convert-notebooks.mjs && astro dev",
    "start": "astro dev",
    "build": "npm run format && node scripts/convert-notebooks.mjs && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write 'src/**/*.{md,mdx}' && node scripts/format-code-blocks.mjs",
