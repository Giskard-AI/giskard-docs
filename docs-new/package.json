    "format:code": "node scripts/format-code-blocks.mjs"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.12",
    "@astrojs/react": "^4.4.2",
    "@astrojs/starlight": "^0.37.6",
    "@astrojs/tailwind": "^6.0.2",
    "astro": "^5.6.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.2",
    "starlight-auto-sidebar": "^0.1.4",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "wrangler": "^4.64.0"
  }
}
