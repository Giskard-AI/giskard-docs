---
interface Props {
  name: string;
  description: string;
}

const { name, description } = Astro.props;
---

<div class="resource-section">
  <div class="resource-section-header">
    <div class="resource-section-dot"></div>
    <div>
      <code class="resource-section-name">{name}</code>
      <p class="resource-section-description">{description}</p>
    </div>
  </div>
  <div class="resource-section-body">
    <slot />
  </div>
</div>

<style>
  .resource-section {
    margin: 2rem 0;
  }

  .resource-section-header {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--api-resource-accent);
    margin-bottom: 1.5rem;
  }

  .resource-section-dot {
    width: 10px;
    height: 10px;
    min-width: 10px;
    border-radius: 50%;
    margin-top: 0.4rem;
    background: var(--api-resource-accent);
  }

  .resource-section-name {
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--sl-color-text);
    background: none;
    padding: 0;
  }

  .resource-section-description {
    font-size: 0.875rem;
    margin: 0.25rem 0 0 0;
    color: var(--sl-color-gray-2, #6b7280);
    line-height: 1.5;
  }

  .resource-section-body {
    padding-left: 0;
  }

  /* Light mode */
  :root:not([data-theme='dark']) {
    --api-resource-accent: #0F1729;
  }

  /* Dark mode */
  :root[data-theme='dark'] {
    --api-resource-accent: #05d939;
  }

  :root[data-theme='dark'] .resource-section-description {
    color: rgba(198, 255, 255, 0.7);
  }
</style>
