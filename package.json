{
  "name": "giskard-docs",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "dev": "node scripts/convert-notebooks.mjs && astro dev",
    "start": "astro dev",
    "build": "pnpm run format && node scripts/convert-notebooks.mjs && astro build && node scripts/generate-redirects.mjs",
    "build:ci": "node scripts/convert-notebooks.mjs && astro build && node scripts/generate-redirects.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write 'src/**/*.{md,mdx}' && node scripts/format-code-blocks.mjs",
    "format:prose": "prettier --write 'src/**/*.{md,mdx}'",
    "format:code": "node scripts/format-code-blocks.mjs",
    "test:tables": "node scripts/check-mdx-tables.mjs",
    "test:redirects": "node scripts/check-redirects.mjs"
  },
  "dependencies": {
    "@astrojs/cloudflare": "13.7.0",
    "@astrojs/starlight": "0.41.1",
    "@tailwindcss/vite": "4.3.2",
    "astro": "6.3.8",
    "astro-mermaid": "2.1.0",
    "mermaid": "11.16.0",
    "sharp": "0.35.2",
    "starlight-auto-sidebar": "0.4.0",
    "starlight-image-zoom": "0.15.0",
    "tailwindcss": "4.3.2"
  },
  "devDependencies": {
    "prettier": "3.9.3",
    "wrangler": "4.105.0"
  }
}
