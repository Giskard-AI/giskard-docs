---
import Default from '@astrojs/starlight/components/Pagination.astro';
---

<div class="pagination-wrapper">
    <Default {...Astro.props} />
</div>

<style>
    /* Pagination Buttons Alignment */
    .pagination-wrapper :global(.pagination-links) {
        display: flex;
        gap: 1rem;
        justify-content: flex-end; /* Align to right by default like 'Next' buttons */
        margin-top: 3rem;
        border-top: 1px solid var(--sl-color-hairline);
        padding-top: 2rem;
    }

    .pagination-wrapper :global(.pagination-links a) {
        display: inline-flex !important;
        flex-direction: column;
        align-items: flex-end;
        text-decoration: none !important;
        padding: 8px 16px !important;
        border: 1px solid #e5e7eb !important;
        border-radius: 6px !important;
        background-color: transparent !important;
        width: auto !important;
        min-width: 150px;
        gap: 0.25rem;
        transition: background-color 0.2s ease, border-color 0.2s ease;
    }

    :global(:root[data-theme='dark']) .pagination-wrapper :global(.pagination-links a) {
        border-color: rgba(64, 222, 223, 0.13) !important;
    }

    .pagination-wrapper :global(.pagination-links a:hover) {
        background-color: var(--sl-color-accent-low) !important;
    }

    /* Pagination Labels */
    .pagination-wrapper :global(.pagination-links .link-title) {
        color: #0F1729 !important;
        font-size: 14px !important;
        font-weight: 600 !important;
        text-align: right;
    }

    :global(:root[data-theme='dark']) .pagination-wrapper :global(.pagination-links .link-title) {
        color: #c6ffff !important;
    }

    .pagination-wrapper :global(.pagination-links .link-label) {
        color: rgba(15, 23, 41, 0.6) !important;
        font-size: 12px !important;
        text-transform: none !important;
        text-align: right;
    }

    :global(:root[data-theme='dark']) .pagination-wrapper :global(.pagination-links .link-label) {
        color: rgba(198, 255, 255, 0.6) !important;
    }

    /* Adjust for Previous link if exists */
    .pagination-wrapper :global(.pagination-links a[rel="prev"]) {
        align-items: flex-start;
        margin-right: auto;
    }

    .pagination-wrapper :global(.pagination-links a[rel="prev"] .link-title),
    .pagination-wrapper :global(.pagination-links a[rel="prev"] .link-label) {
        text-align: left;
    }
</style>
