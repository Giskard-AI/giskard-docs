---
import { isCollapsibleByDefault, typeAnchorId } from "./linkifyType";

interface Props {
  name: string;
  collapsible?: boolean;
  defaultOpen?: boolean;
}

const { name, collapsible, defaultOpen } = Astro.props;
const pathname = Astro.url?.pathname ?? "";
const isCollapsible = collapsible ?? isCollapsibleByDefault(pathname);
const isOpen = isCollapsible ? (defaultOpen ?? false) : true;
const anchorId = typeAnchorId(name);
---

<div
  class="literal-type"
  data-open={String(isOpen)}
  data-collapsible={String(isCollapsible)}
  id={anchorId}
>
  {
    isCollapsible ? (
      <button
        class="literal-type-header"
        aria-expanded={String(isOpen)}
        aria-controls={`${anchorId}-body`}
      >
        <code class="literal-type-name">{name}</code>
        <span class="literal-type-badge">literal</span>
        <svg
          class="literal-type-chevron"
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M4 6l4 4 4-4"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </button>
    ) : (
      <div class="literal-type-header">
        <code class="literal-type-name">{name}</code>
        <span class="literal-type-badge">literal</span>
      </div>
    )
  }
  <div class="literal-type-body" id={`${anchorId}-body`}>
    <slot />
  </div>
</div>

<script>
  function toggleLiteralType(header: Element) {
    const parent = header.closest(".literal-type")!;
    const isOpen = parent.getAttribute("data-open") === "true";
    parent.setAttribute("data-open", String(!isOpen));
    header.setAttribute("aria-expanded", String(!isOpen));
  }

  document.addEventListener("click", (event) => {
    const target = event.target as Element;
    const header = target.closest(".literal-type-header");
    if (!header) return;
    const parent = header.closest(".literal-type");
    if (!parent || parent.getAttribute("data-collapsible") !== "true") return;
    toggleLiteralType(header);
  });

  document.addEventListener("keydown", (event) => {
    if (event.key !== "Enter" && event.key !== " ") return;
    const target = event.target as Element;
    const header = target.closest(".literal-type-header");
    if (!header) return;
    const parent = header.closest(".literal-type");
    if (!parent || parent.getAttribute("data-collapsible") !== "true") return;
    event.preventDefault();
    toggleLiteralType(header);
  });

  // Auto-expand and scroll when the URL hash targets a literal type.
  function openMatchingLiteralType() {
    const hash = window.location.hash.slice(1);
    if (!hash.startsWith("type-")) return;
    const el = document.getElementById(hash);
    if (!el || !el.classList.contains("literal-type")) return;

    if (el.getAttribute("data-collapsible") === "true") {
      el.setAttribute("data-open", "true");
      const button = el.querySelector(".literal-type-header");
      if (button) button.setAttribute("aria-expanded", "true");
    }

    requestAnimationFrame(() => {
      el.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  }

  window.addEventListener("hashchange", openMatchingLiteralType);
  document.addEventListener("astro:page-load", openMatchingLiteralType);
  if (document.readyState !== "loading") {
    openMatchingLiteralType();
  } else {
    document.addEventListener("DOMContentLoaded", openMatchingLiteralType);
  }
</script>

<style>
  .literal-type {
    border: 1px solid var(--sl-color-hairline);
    border-radius: 8px;
    margin: 1rem 0;
    overflow: hidden;
    scroll-margin-top: 5rem;
  }

  .literal-type:target {
    border-color: var(--api-literal-accent);
    box-shadow: 0 0 0 1px var(--api-literal-accent);
  }

  .literal-type-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    width: 100%;
    background: var(--api-type-table-header-bg);
    user-select: none;
    border: none;
    text-align: left;
    font-family: inherit;
    color: inherit;
  }

  .literal-type[data-collapsible="true"] .literal-type-header {
    cursor: pointer;
  }

  .literal-type[data-collapsible="true"] .literal-type-header:hover {
    filter: brightness(0.97);
  }

  :root[data-theme="dark"]
    .literal-type[data-collapsible="true"]
    .literal-type-header:hover {
    filter: brightness(1.15);
  }

  .literal-type-header:focus-visible {
    outline: 2px solid var(--api-literal-accent);
    outline-offset: -2px;
  }

  .literal-type-name {
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--sl-color-text);
    background: none;
    padding: 0;
  }

  .literal-type-badge {
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    margin-right: auto;
    color: var(--api-literal-accent);
    background: var(--api-literal-badge-bg);
  }

  .literal-type-chevron {
    margin-left: auto;
    transition: transform 0.2s ease;
    color: var(--sl-color-gray-3, #9ca3af);
    flex-shrink: 0;
  }

  .literal-type[data-open="true"] .literal-type-chevron {
    transform: rotate(180deg);
  }

  .literal-type-body {
    padding: 0.375rem 1rem 0.5rem;
  }

  .literal-type[data-open="false"] .literal-type-body {
    display: none;
  }

  /* Light mode */
  :root:not([data-theme="dark"]) {
    --api-type-table-header-bg: #fafafa;
    --api-literal-accent: #7c3aed;
    --api-literal-badge-bg: #f5f3ff;
  }

  /* Dark mode */
  :root[data-theme="dark"] {
    --api-type-table-header-bg: #0d3636;
    --api-literal-accent: #c4b5fd;
    --api-literal-badge-bg: rgba(196, 181, 253, 0.1);
  }
</style>
