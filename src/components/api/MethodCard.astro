---
import { linkifyType } from "./linkifyType";

interface Props {
  name: string;
  returnType?: string;
  /**
   * Whether the method body is expanded by default. Methods are collapsed
   * by default to keep resource sections scannable; click the header to expand.
   */
  defaultOpen?: boolean;
}

const { name, returnType, defaultOpen = false } = Astro.props;
const returnTypeHtml = returnType ? linkifyType(returnType) : null;
---

<div class="method-card" data-open={String(defaultOpen)}>
  <div
    class="method-card-header"
    role="button"
    tabindex="0"
    aria-expanded={String(defaultOpen)}
    onclick="
    // Skip toggle when the click originated on a link inside the header
    // (e.g. the linkified return type pointing at #type-Agent).
    if (event.target.closest('a')) return;
    const card = this.closest('.method-card');
    const isOpen = card.getAttribute('data-open') === 'true';
    card.setAttribute('data-open', String(!isOpen));
    this.setAttribute('aria-expanded', String(!isOpen));
  "
    onkeydown="
    if (event.key !== 'Enter' && event.key !== ' ') return;
    if (event.target.tagName === 'A') return;
    event.preventDefault();
    const card = this.closest('.method-card');
    const isOpen = card.getAttribute('data-open') === 'true';
    card.setAttribute('data-open', String(!isOpen));
    this.setAttribute('aria-expanded', String(!isOpen));
  "
  >
    <code class="method-card-name">{name}</code>
    {returnTypeHtml && (
      <span class="method-card-returns">
        <span class="method-card-returns-arrow">&rarr;</span>
        <code set:html={returnTypeHtml} />
      </span>
    )}
    <svg
      class="method-card-chevron"
      width="16"
      height="16"
      viewBox="0 0 16 16"
      fill="none"
      aria-hidden="true"
    >
      <path
        d="M4 6l4 4 4-4"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      ></path>
    </svg>
  </div>
  <div class="method-card-body">
    <slot />
  </div>
</div>

<style>
  .method-card {
    border: 1px solid var(--sl-color-hairline);
    border-radius: 8px;
    margin: 1.25rem 0;
    overflow: hidden;
    scroll-margin-top: 5rem;
  }

  .method-card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 0.75rem 1rem;
    background: var(--api-method-header-bg);
    cursor: pointer;
    user-select: none;
    /* Bottom border only when expanded — collapsed cards have no body
       below the header, so the divider would float in space. */
  }

  .method-card[data-open="true"] .method-card-header {
    border-bottom: 1px solid var(--sl-color-hairline);
  }

  .method-card-header:hover {
    filter: brightness(0.97);
  }

  :root[data-theme="dark"] .method-card-header:hover {
    filter: brightness(1.15);
  }

  .method-card-header:focus-visible {
    outline: 2px solid var(--api-return-color);
    outline-offset: -2px;
  }

  .method-card-name {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--sl-color-text);
    background: none;
    padding: 0;
    /* Push everything that follows to the right edge. */
    margin-right: auto;
  }

  .method-card-returns {
    font-size: 0.8rem;
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .method-card-returns-arrow {
    color: var(--sl-color-gray-3, #9ca3af);
    font-size: 0.9rem;
  }

  .method-card-returns code {
    font-size: 0.8rem;
    padding: 0.125rem 0.5rem;
    border-radius: 4px;
    color: var(--api-return-color);
    background: var(--api-return-bg);
  }

  .method-card-returns code :global(.api-type-link) {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px dashed currentColor;
    transition: border-bottom-color 0.15s ease, opacity 0.15s ease;
  }

  .method-card-returns code :global(.api-type-link:hover) {
    border-bottom-style: solid;
    opacity: 0.85;
  }

  .method-card-chevron {
    color: var(--sl-color-gray-3, #9ca3af);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .method-card[data-open="true"] .method-card-chevron {
    transform: rotate(180deg);
  }

  .method-card-body {
    padding: 1rem;
  }

  .method-card[data-open="false"] .method-card-body {
    display: none;
  }

  /* Light mode */
  :root:not([data-theme="dark"]) {
    --api-method-header-bg: #f8fafc;
    --api-return-color: #059669;
    --api-return-bg: #ecfdf5;
  }

  /* Dark mode */
  :root[data-theme="dark"] {
    --api-method-header-bg: #0d3636;
    --api-return-color: #05d939;
    --api-return-bg: rgba(5, 217, 57, 0.1);
  }
</style>
