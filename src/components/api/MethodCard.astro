---
import {
  getTypeLinkConfig,
  isCollapsibleByDefault,
  linkifyType,
} from "./linkifyType";

interface Props {
  name: string;
  returnType?: string;
  /**
   * Whether the method body is rendered as a collapsible accordion.
   * If omitted, defaults to true on the Hub SDK reference (long page,
   * many methods) and false on the OSS Checks reference (short pages
   * where users want everything visible).
   */
  collapsible?: boolean;
  /**
   * Whether a collapsible card starts expanded. Ignored when
   * `collapsible` is false (the body is always visible).
   */
  defaultOpen?: boolean;
}

const { name, returnType, collapsible, defaultOpen } = Astro.props;
const pathname = Astro.url?.pathname ?? "";
const { knownTypes, typePages } = getTypeLinkConfig(pathname);
const returnTypeHtml = returnType
  ? linkifyType(returnType, knownTypes, pathname, typePages)
  : null;

const isCollapsible = collapsible ?? isCollapsibleByDefault(pathname);
// When the card is non-collapsible, force it open. When collapsible, honour
// `defaultOpen` (default closed) so the page renders compact.
const isOpen = isCollapsible ? (defaultOpen ?? false) : true;
// Stable id for the body so the header can reference it via aria-controls.
// crypto.randomUUID() is evaluated once per render, so the id remains
// consistent within a single page render.
const bodyId = `method-body-${crypto.randomUUID()}`;
---

<div
  class="method-card"
  data-open={String(isOpen)}
  data-collapsible={String(isCollapsible)}
>
  <div
    class="method-card-header"
    role={isCollapsible ? "button" : undefined}
    tabindex={isCollapsible ? "0" : undefined}
    aria-expanded={isCollapsible ? String(isOpen) : undefined}
    aria-controls={isCollapsible ? bodyId : undefined}
  >
    <code class="method-card-name">{name}</code>
    {returnTypeHtml && (
      <span class="method-card-returns">
        <span class="method-card-returns-arrow">&rarr;</span>
        <code set:html={returnTypeHtml} />
      </span>
    )}
    {isCollapsible && (
      <svg
        class="method-card-chevron"
        width="16"
        height="16"
        viewBox="0 0 16 16"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M4 6l4 4 4-4"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    )}
  </div>
  <div class="method-card-body" id={bodyId}>
    <slot />
  </div>
</div>

<style>
  .method-card {
    border: 1px solid var(--sl-color-hairline);
    border-radius: 8px;
    margin: 1.25rem 0;
    overflow: hidden;
    scroll-margin-top: 5rem;
  }

  .method-card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 0.75rem 1rem;
    background: var(--api-method-header-bg);
    user-select: none;
    /* Bottom border only when expanded — collapsed cards have no body
       below the header, so the divider would float in space. */
  }

  .method-card[data-collapsible="true"] .method-card-header {
    cursor: pointer;
  }

  .method-card[data-open="true"] .method-card-header {
    border-bottom: 1px solid var(--sl-color-hairline);
  }

  .method-card[data-collapsible="true"] .method-card-header:hover {
    filter: brightness(0.97);
  }

  :root[data-theme="dark"]
    .method-card[data-collapsible="true"]
    .method-card-header:hover {
    filter: brightness(1.15);
  }

  .method-card-header:focus-visible {
    outline: 2px solid var(--api-type-color, #6366f1);
    outline-offset: -2px;
  }

  .method-card-name {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--sl-color-text);
    background: none;
    padding: 0;
    /* Push everything that follows to the right edge. */
    margin-right: auto;
  }

  .method-card-returns {
    font-size: 0.8rem;
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .method-card-returns-arrow {
    color: var(--sl-color-gray-3, #9ca3af);
    font-size: 0.9rem;
  }

  .method-card-returns code {
    font-size: 0.8rem;
    padding: 0.125rem 0.5rem;
    border-radius: 4px;
    color: var(--api-return-color);
    background: var(--api-return-bg);
  }

  .method-card-returns code :global(.api-type-link) {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px dashed currentColor;
    transition: border-bottom-color 0.15s ease, opacity 0.15s ease;
  }

  .method-card-returns code :global(.api-type-link:hover) {
    border-bottom-style: solid;
    opacity: 0.85;
  }

  .method-card-chevron {
    color: var(--sl-color-gray-3, #9ca3af);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .method-card[data-open="true"] .method-card-chevron {
    transform: rotate(180deg);
  }

  .method-card-body {
    padding: 1rem;
  }

  .method-card[data-open="false"] .method-card-body {
    display: none;
  }

  /* Light mode */
  :root:not([data-theme="dark"]) {
    --api-method-header-bg: #f8fafc;
    --api-return-color: #059669;
    --api-return-bg: #ecfdf5;
  }

  /* Dark mode */
  :root[data-theme="dark"] {
    --api-method-header-bg: #0d3636;
    --api-return-color: #05d939;
    --api-return-bg: rgba(5, 217, 57, 0.1);
  }
</style>

<script>
  function toggleCard(header: Element) {
    const card = header.closest(".method-card")!;
    const isOpen = card.getAttribute("data-open") === "true";
    card.setAttribute("data-open", String(!isOpen));
    header.setAttribute("aria-expanded", String(!isOpen));
  }

  document.addEventListener("click", (event) => {
    const target = event.target as Element;
    if (target.closest("a")) return;
    const header = target.closest(".method-card-header");
    if (!header) return;
    const card = header.closest(".method-card");
    if (!card || card.getAttribute("data-collapsible") !== "true") return;
    toggleCard(header);
  });

  document.addEventListener("keydown", (event) => {
    if (event.key !== "Enter" && event.key !== " ") return;
    const target = event.target as Element;
    if (target.closest("a")) return;
    const header = target.closest(".method-card-header");
    if (!header) return;
    const card = header.closest(".method-card");
    if (!card || card.getAttribute("data-collapsible") !== "true") return;
    event.preventDefault();
    toggleCard(header);
  });
</script>
