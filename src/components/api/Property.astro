---
import { getTypeLinkConfig, linkifyType } from "./linkifyType";

interface Props {
  name: string;
  type: string;
  required?: boolean;
  defaultValue?: string;
}

const { name, type, required = false, defaultValue } = Astro.props;
const pathname = Astro.url?.pathname ?? "";
const { knownTypes, typePages } = getTypeLinkConfig(pathname);
const typeHtml = linkifyType(type, knownTypes, pathname, typePages);
---

<div class="api-property">
  <div class="api-property-header">
    <code class="api-property-name">{name}</code>
    <span class="api-property-type" set:html={typeHtml} />
    {required && <span class="api-property-required">Required</span>}
    {!required && defaultValue && <span class="api-property-default">Default: <code>{defaultValue}</code></span>}
  </div>
  <div class="api-property-description">
    <slot />
  </div>
</div>

<style>
  .api-property {
    padding: 0.875rem 0;
    border-top: 1px solid var(--sl-color-hairline);
  }

  .api-property:first-child {
    border-top: none;
    padding-top: 0;
  }

  .api-property-header {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
    margin-bottom: 0.375rem;
  }

  .api-property-name {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--sl-color-text);
    background: none;
    padding: 0;
  }

  .api-property-type {
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    font-size: 0.8rem;
    padding: 0.125rem 0.5rem;
    border-radius: 4px;
    color: var(--api-type-color);
    background: var(--api-type-bg);
  }

  .api-property-type :global(.api-type-link) {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px dashed currentColor;
    transition: border-bottom-color 0.15s ease, opacity 0.15s ease;
  }

  .api-property-type :global(.api-type-link:hover) {
    border-bottom-style: solid;
    opacity: 0.85;
  }

  .api-property-required {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.125rem 0.4rem;
    border-radius: 4px;
    color: var(--api-required-color);
    background: var(--api-required-bg);
  }

  .api-property-default {
    font-size: 0.75rem;
    color: var(--sl-color-gray-3, #6b7280);
  }

  .api-property-default code {
    font-size: 0.75rem;
    background: none;
    padding: 0;
  }

  .api-property-description {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--sl-color-gray-2, #4b5563);
  }

  /* Light mode */
  :root:not([data-theme='dark']) {
    --api-type-color: #6366f1;
    --api-type-bg: #eef2ff;
    --api-required-color: #dc2626;
    --api-required-bg: #fef2f2;
  }

  /* Dark mode */
  :root[data-theme='dark'] {
    --api-type-color: #40dedf;
    --api-type-bg: rgba(64, 222, 223, 0.1);
    --api-required-color: #f87171;
    --api-required-bg: rgba(248, 113, 113, 0.1);
  }

  :root[data-theme='dark'] .api-property-description {
    color: rgba(198, 255, 255, 0.7);
  }

  :root[data-theme='dark'] .api-property-default {
    color: rgba(198, 255, 255, 0.5);
  }
</style>
